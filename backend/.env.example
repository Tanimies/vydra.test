# Main Database
# For local development you can omit this and SQLite will be used.
# For Supabase/Postgres use the direct connection string from
# Supabase -> Project Settings -> Database -> Connection string -> URI
DATABASE_URL=

# Supabase Configuration
# Leave these blank for local development; fill in production values for hosted deployment.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_DOCUMENTS_BUCKET=documents

# Groq API (FREE TIER - 500 requests/day)
GROQ_API_KEY=

# JWT Secret
SECRET_KEY=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Qdrant Configuration (LOCAL or FREE TIER)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Agentic learning chat web fallback
TRUSTED_SEARCH_DOMAINS=["khanacademy.org", "britannica.com", "nih.gov", "nasa.gov", ".edu/"]
WEB_FALLBACK_TOP_K=4

# TURN placeholders for in-product classroom meetings
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Environment
ENVIRONMENT=development
DEBUG=False

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
